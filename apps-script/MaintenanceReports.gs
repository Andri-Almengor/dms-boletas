function apiMaintenanceSpreadsheetReport_(ctx){var id=maintenanceId_(ctx.payload),data=enrichMaintenance_(requireRecord_(MAINTENANCE_TABLES_.MAINTENANCE,'MantenimientoID',id)),m=data.mantenimiento,folder=maintenanceFolder_(m),title='Mantenimiento DMS - '+(m.Cliente||'Cliente')+' - '+maintenanceDateText_(m.Fecha),report=SpreadsheetApp.create(title);DriveApp.getFileById(report.getId()).moveTo(folder);maintenanceBuildSummarySheet_(report.getSheets()[0],data);var grouped=maintenanceGroupDevices_(data.dispositivos);Object.keys(grouped).forEach(function(category){maintenanceBuildCategorySheet_(report.insertSheet(maintenanceUniqueSheetName_(report,category)),category,grouped[category]);});var url=report.getUrl();updateById_(MAINTENANCE_TABLES_.MAINTENANCE,'MantenimientoID',id,{SpreadsheetID:report.getId(),SpreadsheetURL:url,ActualizadoPor:ctx.user.UsuarioID,FechaActualizacion:new Date()});return{spreadsheetId:report.getId(),spreadsheetUrl:url,excelUrl:'https://docs.google.com/spreadsheets/d/'+report.getId()+'/export?format=xlsx'};}
