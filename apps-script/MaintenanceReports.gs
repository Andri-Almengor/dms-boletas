function maintenanceBuildSummarySheet_(sheet,data){var m=data.mantenimiento;sheet.setName('Resumen');sheet.clear();sheet.getRange('A1:H1').merge().setValue('REPORTE DE MANTENIMIENTO DMS').setFontSize(18).setFontWeight('bold').setFontColor('#ffffff').setBackground('#b7131a').setHorizontalAlignment('center');var rows=[['Título',m.TituloMantenimiento,'Cliente',m.Cliente],['Fecha',m.Fecha,'Fecha finalización',m.FechaFinalizacion],['Ubicación',m.Ubicacion,'Estado',m.Estado],['Responsables',m.Responsables,'Dispositivos',data.dispositivos.length],['Descripción general',m.DescripcionGeneral,'','']];sheet.getRange(3,1,rows.length,4).setValues(rows);sheet.getRange('A3:A7').setFontWeight('bold').setBackground('#fce8ea');sheet.getRange('C3:C7').setFontWeight('bold').setBackground('#fce8ea');sheet.getRange('A3:D7').setWrap(true).setVerticalAlignment('top');sheet.getRange('A9:C9').setValues([['Categoría','Esperados','Registrados']]).setFontWeight('bold').setFontColor('#ffffff').setBackground('#b7131a');var categories=MAINTENANCE_CATEGORIES_.map(function(item){return[item.key,Number(m[item.countField]||0),data.dispositivos.filter(function(device){return device.Categoria===item.key;}).length];});sheet.getRange(10,1,categories.length,3).setValues(categories);sheet.setFrozenRows(1);sheet.autoResizeColumns(1,8);sheet.setColumnWidth(2,260);sheet.setColumnWidth(4,260);}
